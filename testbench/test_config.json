{
  "session": {
    "duration_seconds": 3600,
    "output_directory": "sessions",
    "startup_settle_seconds": 1.5,
    "power_worker_stop_timeout_seconds": 15,
    "abort_on_power_worker_failure": true
  },
  "serial": {
    "port": "COM19",
    "strict_configured_port": false,
    "baudrate": 115200,
    "read_timeout_seconds": 0.25,
    "write_timeout_seconds": 2,
    "reconnect_interval_seconds": 1,
    "silent_warning_seconds": 10,
    "match": {
      "vid": null,
      "pid": null,
      "serial_number": "",
      "description_contains": "USB"
    },
    "startup_commands": [
      "PING",
      "STATUS",
      "SD_TEST",
      "PSRAM_TEST",
      "PROJECT_TEST"
    ]
  },
  "power_faults": {
    "enabled": false,
    "backend": "windows_pnp",
    "mode": "random",
    "startup_delay_seconds": 20,
    "fixed_interval_seconds": 60,
    "random_min_seconds": 30,
    "random_max_seconds": 180,
    "off_duration_seconds": 3,
    "random_seed": null,
    "command_timeout_seconds": 20,
    "recovery_attempts": 5,
    "recovery_retry_seconds": 2,
    "ensure_power_on_at_start": true,
    "ensure_power_on_on_exit": true,
    "windows_pnp": {
      "instance_id": "USB\\VID_0000&PID_0000\\REPLACE_ME"
    },
    "command": {
      "off": [
        "C:\\path\\to\\usb-power-controller.exe",
        "off",
        "1"
      ],
      "on": [
        "C:\\path\\to\\usb-power-controller.exe",
        "on",
        "1"
      ]
    }
  }
}
